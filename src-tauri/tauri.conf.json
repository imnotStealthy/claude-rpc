{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude RPC",
  "version": "3.2.0",
  "identifier": "eu.stealthylabs.claude-rpc",
  "mainBinaryName": "claude-rpc",
  "build": {
    "frontendDist": "../tauri-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": "default-src 'self'; img-src 'self'; style-src 'self'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../logo/anthropic-rpc.ico"]
  }
}
